# Dev server — proxied to the stellar-api backend
STELLAR_API_URL=http://localhost:8080

# Playwright E2E — copy to .env.test.local or export before running `npm run test:e2e`
# API_URL and BASE_URL default to the values below if not set.
API_URL=http://localhost:8080
BASE_URL=http://localhost:9000

# Credentials for pre-seeded test accounts used by Playwright global setup.
# Create these via /install → dev tools, or via `npm run db:seed` in stellar-api.
TEST_USER=testuser
TEST_USER_PASSWORD=changeme
TEST_STAFF_USER=staffuser
TEST_STAFF_PASSWORD=changeme
